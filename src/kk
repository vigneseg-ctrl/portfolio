# ── TOPIC 11: App Router and File-based Routing ───────────────
story.append(topic_header('Topic 11 — App Router and File-based Routing', 'Navigation without React Router', GREEN_LIGHT, TEAL_DARK))
story.append(sp(6))

story.append(label('PLAIN ENGLISH EXPLANATION'))
story.append(body(
    'In plain React you need React Router — you manually define every route with a Route component. '
