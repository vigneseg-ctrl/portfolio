# ── TOPIC 15: TypeScript basics ──────────────────────────────
story.append(topic_header('Topic 15 — Types, Interfaces, Type Aliases', 'The foundation of TypeScript', GREEN_LIGHT, TEAL_DARK))
story.append(sp(6))

story.append(label('PLAIN ENGLISH EXPLANATION'))
story.append(body(
    'In JavaScript, a variable can hold any type of value at any time. '
    'This flexibility causes bugs — you pass a string where a number was expected, '
    'or access a property that does not exist. '
    'TypeScript adds types to your variables, function parameters, and return values. '
    'The TypeScript compiler checks your code before it runs and tells you about mistakes '
    'before your users ever see them.'
))
story.append(sp(6))

story.append(label('LOGICAL UNDERSTANDING'))
story += bullet_row([
    'TypeScript is a superset of JavaScript — every valid JS file is valid TypeScript.',
    'Types are erased at compile time — the browser never sees TypeScript, only the compiled JavaScript.',
    'interface defines the shape of an object — what properties it has and their types.',
    'type alias creates a reusable name for any type — union types, intersection types, primitives.',
    'interface is generally preferred for objects (can be extended, merged). type is better for unions and computed types.',
    'Optional properties use ? — property?: string means the property may or may not exist.',
    'The "as" keyword (type assertion) tells TypeScript to trust you about a type — use it sparingly.',
], TEAL_MID)
story.append(sp(6))

story.append(label('HOW TO SAY IT IN AN INTERVIEW'))
story.append(interview_box(
    'What is the difference between interface and type in TypeScript? When do you use each?',
    'Both interface and type are used to define the shape of objects in TypeScript. '
    'The main differences are: interfaces can be extended with the extends keyword and '
    'can be merged — if you declare the same interface name twice, TypeScript merges them. '
    'Type aliases are more flexible — they can represent union types, intersection types, '
    'tuples, and mapped types that interfaces cannot. '
    'In practice, I use interface for objects that represent entities — User, Product, Order — '
    'because they can be extended when needed. '
    'I use type for unions like type Status = "active" | "inactive" | "pending", '
    'or for utility types and complex type expressions. '
    'Both work fine for most use cases and the difference is usually a team style preference.'
))
story.append(sp(6))

story.append(label('CODE EXAMPLE'))
story.append(code_block([
    '// Basic types',
    'let name: string    = "Vigneswaran";',
    'let age:  number    = 28;',
    'let active: boolean = true;',
    'let scores: number[]  = [85, 90, 78];',
    '',
    '// Interface — shape of an object',
    'interface User {',
    '  id:       number;',
    '  name:     string;',
    '  email:    string;',
    '  role?:    string;   // optional property',
    '}',
    '',
    '// Extend interface',
    'interface AdminUser extends User {',
    '  permissions: string[];',
    '}',
    '',
    '// Type alias — great for unions',
    'type Status   = "active" | "inactive" | "pending";',
    'type ID       = string | number;',
    '',
    '// Type for object (equivalent to interface for objects)',
    'type Product = {',
    '  id:       number;',
    '  name:     string;',
    '  price:    number;',
    '  category: string;',
    '};',
    '',
    '// Using types in functions',
    'function getUser(id: number): User {',
    '  return { id, name: "Vignesh", email: "v@test.com" };',
    '}',
    '',
    '// Function that accepts User or AdminUser',
    'function displayUser(user: User | AdminUser): string {',
    '  return `${user.name} (${user.email})`;',
    '}',
]))
story.append(PageBreak())

# ── TOPIC 16: Generics ────────────────────────────────────────
story.append(topic_header('Topic 16 — Generics', 'Reusable types that work with any data', BLUE_LIGHT, BLUE_DARK))
story.append(sp(6))

story.append(label('PLAIN ENGLISH EXPLANATION'))
story.append(body(
    'Generics are like type variables. Instead of writing a function that only works with strings, '
    'or only with numbers, you write a function that works with any type — '
    'and TypeScript figures out the specific type when you use it. '
    'Think of it like a box. A generic box can hold anything, '
    'but once you put something in it, TypeScript knows exactly what type is inside.'
))
story.append(sp(6))

story.append(label('LOGICAL UNDERSTANDING'))
story += bullet_row([
    'Generic type parameter T is a placeholder — like a variable for a type.',
    'When you call a generic function, TypeScript infers T from the argument you pass.',
    'You can constrain generics: <T extends object> means T must be an object type.',
    'React components, hooks, and utilities are all generic — useState<User | null>(null) is a generic call.',
    'API response types are a perfect use case: type ApiResponse<T> = { data: T; status: number; message: string }',
], BLUE)
story.append(sp(6))

story.append(label('HOW TO SAY IT IN AN INTERVIEW'))
story.append(interview_box(
    'What are generics in TypeScript? Give a real example.',
    'Generics allow you to write reusable, type-safe code that works with multiple types. '
    'Instead of writing the same function multiple times for different types, '
    'or using "any" which removes all type safety, '
    'generics let you parameterise the type like a variable. '
    'A real example I use: an API response wrapper type — '
    'ApiResponse<T> with a data field of type T. '
    'When fetching users, the response type is ApiResponse<User[]>. '
    'When fetching products, it is ApiResponse<Product[]>. '
    'The same wrapper type works for any data. '
    'Another common example is a generic useFetch hook — '
    'function useFetch<T>(url: string): { data: T | null, loading: boolean } — '
    'the caller specifies what type the response will be.'
))
story.append(sp(6))

story.append(label('CODE EXAMPLE'))
story.append(code_block([
    '// Generic function — works with any type',
    'function getFirstItem<T>(arr: T[]): T | undefined {',
    '  return arr[0];',
    '}',
    '',
    'getFirstItem([1, 2, 3]);         // TypeScript knows return is number',
    'getFirstItem(["a", "b", "c"]);   // TypeScript knows return is string',
    '',
    '// Generic API response wrapper',
    'type ApiResponse<T> = {',
    '  data:    T;',
    '  status:  number;',
    '  message: string;',
    '};',
    '',
    'type UserResponse    = ApiResponse<User>;',
    'type ProductResponse = ApiResponse<Product[]>;',
    '',
    '// Generic React hook',
    'function useFetch<T>(url: string) {',
    '  const [data, setData]       = useState<T | null>(null);',
    '  const [loading, setLoading] = useState(true);',
    '  const [error, setError]     = useState<string | null>(null);',
    '',
    '  useEffect(() => {',
    '    fetch(url)',
    '      .then(r => r.json())',
    '      .then((json: T) => setData(json))',
    '      .catch((err: Error) => setError(err.message))',
    '      .finally(() => setLoading(false));',
    '  }, [url]);',
    '',
    '  return { data, loading, error };',
    '}',
    '',
    '// Usage — TypeScript knows exactly what data contains',
    'const { data: users } = useFetch<User[]>("/api/users");',
    '// users is User[] | null — fully typed',
]))
story.append(PageBreak())

