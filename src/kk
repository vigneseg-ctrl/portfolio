def bullet_row(items, dot_color=TEAL_MID):
    rows = []
    for item in items:
        t = Table([[
            Paragraph('•', S('bd', fontName='Helvetica-Bold', fontSize=12, textColor=dot_color, leading=15)),
            Paragraph(safe(item), S('bi', fontName='Helvetica', fontSize=9.5, textColor=DARK, leading=14, alignment=TA_JUSTIFY)),
        ]], colWidths=[0.5*cm, CW-0.5*cm])
        t.setStyle(TableStyle([
            ('TOPPADDING',    (0,0),(-1,-1), 3),
            ('BOTTOMPADDING', (0,0),(-1,-1), 3),
            ('LEFTPADDING',   (0,0),(-1,-1), 4),
            ('RIGHTPADDING',  (0,0),(-1,-1), 4),
            ('VALIGN',        (0,0),(-1,-1), 'TOP'),
        ]))
        rows.append(t)
        rows.append(sp(2))
    return rows

