def S(name, **kw): return ParagraphStyle(name, **kw)
def sp(n=8): return Spacer(1, n)

def divider():
    return HRFlowable(width=CW, thickness=0.5, color=GRAY_BORDER, spaceAfter=6, spaceBefore=6)

def teal_rule():
    return HRFlowable(width=CW, thickness=2.5, color=TEAL, spaceAfter=8, spaceBefore=2)

def safe(text):
    if '<b>' in text or '<br' in text or '<font' in text or '<i>' in text:
        return text
    return text.replace('&','&amp;').replace('<','&lt;').replace('>','&gt;')

def body(text):
    return Paragraph(safe(text), S('b', fontName='Helvetica', fontSize=10, textColor=DARK,
        leading=15, spaceAfter=5, alignment=TA_JUSTIFY))

def label(text, color=MUTED):
    return Paragraph(text, S('lbl', fontName='Helvetica-Bold', fontSize=7.5, textColor=color,
        leading=10, spaceBefore=10, spaceAfter=3, letterSpacing=0.8))

def h1(text):
    return [sp(4),
        Paragraph(safe(text), S('h1', fontName='Helvetica-Bold', fontSize=19,
            textColor=DARK, leading=23, spaceAfter=4)),
        teal_rule(), sp(2)]

def h2(text, color=TEAL):
    return Paragraph(safe(text), S('h2', fontName='Helvetica-Bold', fontSize=13,
        textColor=color, spaceBefore=14, spaceAfter=5, leading=17))

def h3(text, color=DARK):
    return Paragraph(safe(text), S('h3', fontName='Helvetica-Bold', fontSize=11,
        textColor=color, spaceBefore=10, spaceAfter=4, leading=15))

def code_block(lines):
    rows = [[Paragraph(
    safe(ln) if ln.strip() else ' ',
    S(
        'cl',
        fontName='Courier',
        fontSize=8.5,
        textColor=CODE_FG,
        leading=13,
        leftIndent=4
    )
)] for ln in lines]
    t = Table(rows, colWidths=[CW])
    t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(-1,-1), CODE_BG),
        ('TOPPADDING',    (0,0),(-1,-1), 2),
        ('BOTTOMPADDING', (0,0),(-1,-1), 2),
        ('LEFTPADDING',   (0,0),(-1,-1), 8),
        ('RIGHTPADDING',  (0,0),(-1,-1), 8),
        ('TOPPADDING',    (0,0),(0,0),   8),
        ('BOTTOMPADDING', (0,-1),(0,-1), 8),
    ]))
    return t

def box(lbl_text, content, bg, border, lc, tc=None):
    tc = tc or DARK
    sc = content if ('<b>' in content or '<br' in content or '<font' in content) else safe(content)
    rows = [
        [Paragraph(lbl_text, S('bl', fontName='Helvetica-Bold', fontSize=9.5, textColor=lc, leading=13))],
        [Paragraph(sc, S('bc', fontName='Helvetica', fontSize=9.5, textColor=tc, leading=14, alignment=TA_JUSTIFY))],
    ]
    t = Table(rows, colWidths=[CW])
    t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(-1,-1), bg),
        ('LINEBEFORE',    (0,0),(-1,-1), 3, border),
        ('LINEABOVE',     (0,0),(-1,0),  1, border),
        ('LINEBELOW',     (0,-1),(-1,-1),1, border),
        ('TOPPADDING',    (0,0),(-1,-1), 6),
        ('BOTTOMPADDING', (0,0),(-1,-1), 6),
        ('LEFTPADDING',   (0,0),(-1,-1), 10),
        ('RIGHTPADDING',  (0,0),(-1,-1), 10),
    ]))
    return t

def interview_box(question, answer):
    q_row = [Paragraph(f'<b>Q: {safe(question)}</b>',
        S('iq', fontName='Helvetica-Bold', fontSize=9.5, textColor=BLUE_DARK, leading=13))]
    a_row = [Paragraph(f'<b>A:</b> {safe(answer)}',
        S('ia', fontName='Helvetica', fontSize=9.5, textColor=DARK, leading=14, alignment=TA_JUSTIFY))]
    t = Table([q_row, a_row], colWidths=[CW])
    t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(0,0), BLUE_LIGHT),
        ('BACKGROUND',    (0,1),(0,1), WHITE),
        ('LINEBEFORE',    (0,0),(-1,-1), 3, BLUE),
        ('LINEABOVE',     (0,0),(-1,0),  1, BLUE),
        ('LINEBELOW',     (0,-1),(-1,-1),1, BLUE),
        ('TOPPADDING',    (0,0),(-1,-1), 6),
        ('BOTTOMPADDING', (0,0),(-1,-1), 6),
        ('LEFTPADDING',   (0,0),(-1,-1), 10),
        ('RIGHTPADDING',  (0,0),(-1,-1), 10),
    ]))
    return t

def topic_header(title, subtitle, bg, fg):
    t = Table([[
        Paragraph(f'<b>{safe(title)}</b>',
            S('th', fontName='Helvetica-Bold', fontSize=13, textColor=fg, leading=17)),
        Paragraph(safe(subtitle),
