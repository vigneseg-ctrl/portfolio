# ── TOPIC 17: Web Performance ─────────────────────────────────
story.append(topic_header('Topic 17 — Web Performance and Core Web Vitals', 'What interviewers ask about performance', PURPLE_LIGHT, PURPLE_DARK))
story.append(sp(6))

story.append(label('PLAIN ENGLISH EXPLANATION'))
story.append(body(
    'Web performance is about how fast your page loads and how responsive it feels. '
    'Google measures this with Core Web Vitals — three metrics that directly affect SEO rankings. '
    'LCP (Largest Contentful Paint) measures how long until the main content is visible. '
    'FID/INP measures how fast the page responds to interaction. '
    'CLS measures how much the layout shifts unexpectedly while loading.'
))
story.append(sp(6))

story.append(label('LOGICAL UNDERSTANDING'))
story += bullet_row([
    'LCP (Largest Contentful Paint) — target under 2.5 seconds. Improve by: preloading hero images, using next/image priority, faster server response.',
    'INP (Interaction to Next Paint, replaced FID) — target under 200ms. Improve by: breaking up long JavaScript tasks, using web workers.',
    'CLS (Cumulative Layout Shift) — target under 0.1. Improve by: always specifying image dimensions, reserving space for ads/embeds.',
    'Code splitting: break your bundle into smaller chunks. React.lazy() and dynamic import() load components only when needed.',
    'Tree shaking: bundlers (Webpack, Vite) remove unused code automatically. Only import what you use.',
    'Lighthouse in Chrome DevTools scores your page and tells you exactly what to fix.',
], PURPLE)
story.append(sp(6))

story.append(label('HOW TO SAY IT IN AN INTERVIEW'))
story.append(interview_box(
    'How do you optimise the performance of a React application?',
    'I approach performance optimisation in layers. '
    'At the bundle level: code splitting with React.lazy and dynamic imports so users only download code they need. '
    'Tree shaking to remove unused dependencies. '
    'At the rendering level: React.memo to prevent unnecessary component re-renders. '
    'useCallback and useMemo to avoid recreating functions and values every render. '
    'Virtualization for long lists using react-window. '
